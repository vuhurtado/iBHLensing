Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"lam", "[", "x_", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", "2"}], ")"}], "*", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"1", "/", "2"}], " ", "-", " ", "x"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"1", "/", "2"}], " ", "+", " ", 
         RowBox[{"3", "x"}]}], ")"}]}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"1", "/", "4"}], ")"}]}]}]}]}]], "Input",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{
  3.956859902281658*^9, {3.9568606454822063`*^9, 3.956860668262453*^9}, {
