Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", "2"], "-", "x"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", "2"], "+", 
       RowBox[{"3", " ", "x"}]}], ")"}]}], ")"}], 
   RowBox[{"1", "/", "4"}]]}]], "Output",
